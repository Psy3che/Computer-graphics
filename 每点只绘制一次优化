float x0 = 300,
      y0 = 300,
      r = 200,
      n = 15;

void setup() {
  size(600, 600);
}

void draw() {
  noLoop();
  noFill();
  beginShape(LINES);

  // 第一个点 t1
  for (float t1 = 0; t1 < 2 * PI; t1 += 2*PI/n) {
    
    // ✅ 关键修改：t2 从 t1 的下一个点开始！
    for (float t2 = t1 + 2*PI/n; t2 < 2 * PI; t2 += 2*PI/n) {
      
      // 每对点只画 一次
      vertex(x0 + r * cos(t1), y0 + r * sin(t1));
      vertex(x0 + r * cos(t2), y0 + r * sin(t2));
    }
  }

  endShape();
}
